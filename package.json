{
  "name": "marketplace-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @repo/standard dev",
    "dev:split": "turbo run dev --filter=@repo/users --filter=@repo/sellers --filter=@repo/admin",
    "build": "pnpm --filter @repo/standard build",
    "build:all": "turbo run build",
    "lint": "pnpm --filter @repo/standard lint",
    "lint:all": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
