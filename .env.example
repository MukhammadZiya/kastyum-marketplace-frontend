# Public API base URL (must match backend PORT, default 3000). If the API is not running
# on that host/port, Telegram/email login will fail with a connection error in the browser.
# Vite only exposes variables prefixed with VITE_ to the browser.
VITE_API_BASE_URL=http://localhost:3000

# Cross-app URLs (fixed ports from each app’s vite.config.ts — do not point sellers at admin).
# Marketplace (users): apps/users Vite → 127.0.0.1:5173 (do not use :80 without sudo).
# Sellers portal:      http://localhost:5174  ← VITE_SELLER_APP_ORIGIN must be THIS app only
# Admin:               http://localhost:5175
#
# Users app: “I’m selling” opens this origin in a new tab (must be sellers, not admin).
VITE_SELLER_APP_ORIGIN=http://localhost:5174
# Must match users app origin (port in apps/users/vite.config.ts).
VITE_MARKETPLACE_ORIGIN=http://127.0.0.1:5173/

# Telegram Login widget — public bot USERNAME only (no @), never the bot token.
# The token must only exist in the API .env; putting it in VITE_* would leak it in the browser bundle.
# "Bot domain invalid" = register this site’s origin in @BotFather (Domain), not a missing token here.
VITE_TELEGRAM_BOT_NAME=iBerry_marketplace_bot

# Do not put MONGODB_URI, JWT_SECRET, TELEGRAM_BOT_TOKEN, or any server secrets here.
