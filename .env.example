# Public API base URL (must match backend PORT, default 3000).
# Vite only exposes variables prefixed with VITE_ to the browser.
VITE_API_BASE_URL=http://localhost:3000

# Cross-app URLs (fixed ports from each app’s vite.config.ts — do not point sellers at admin).
# Marketplace (users): http://localhost:5173
# Sellers portal:      http://localhost:5174  ← VITE_SELLER_APP_ORIGIN must be THIS app only
# Admin:               http://localhost:5175
#
# Users app: “I’m selling” opens this origin in a new tab (must be sellers, not admin).
VITE_SELLER_APP_ORIGIN=http://localhost:5174
# Sellers app: “Shopping instead?” link to buyer signup on the marketplace.
VITE_MARKETPLACE_ORIGIN=http://localhost:5173

# Do not put MONGODB_URI, JWT_SECRET, or other server secrets here — they belong
# only in kastyum-marketplace-backend/.env and must never be bundled into the SPA.
