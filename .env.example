# Public API base URL (must match backend PORT, default 3000).
# Vite only exposes variables prefixed with VITE_ to the browser.
VITE_API_BASE_URL=http://localhost:3000

# Do not put MONGODB_URI, JWT_SECRET, or other server secrets here — they belong
# only in kastyum-marketplace-backend/.env and must never be bundled into the SPA.
